{
  "name": "voice-channel",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "electron-dev": "electron .",
    "electron-build": "vite build && electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.4",
    "@tailwindcss/vite": "^4.2.1",
    "@zag-js/menu": "^1.35.3",
    "@zag-js/solid": "^1.35.3",
    "electron-vite": "^5.0.0",
    "events": "^3.3.0",
    "solid-devtools": "^0.34.5",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.3",
    "stanza": "^12.21.1",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.v3xlabs.voicechannel",
    "productName": "voice-channel",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
