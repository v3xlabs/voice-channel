  "query": "\n            UPDATE users \n            SET display_name = COALESCE($2, display_name),\n                passkey_id = COALESCE($3, passkey_id),\n                updated_at = NOW()\n            WHERE id = $1\n            RETURNING id, username, display_name, instance_fqdn, passkey_id, created_at, updated_at\n            ",
