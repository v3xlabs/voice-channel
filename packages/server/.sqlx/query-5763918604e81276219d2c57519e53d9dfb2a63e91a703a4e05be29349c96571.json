{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT u.user_id, u.username, u.display_name, u.instance_fqdn, u.is_admin, u.created_at, u.updated_at\n            FROM users u\n            JOIN group_memberships gm ON u.user_id = gm.user_id\n            WHERE gm.group_id = $1\n            ORDER BY gm.created_at ASC\n            ",
